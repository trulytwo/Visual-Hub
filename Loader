-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 4483362458)

local DupeItemName = ""
local isDuping = false

DupeTab:CreateInput({
    Name = "Item Name(s)",
    PlaceholderText = "Aura Crate, Cosmetic Crate",
    Callback = function(v) DupeItemName = v end
})

DupeTab:CreateButton({
    Name = "Dupe (2x)",
    Callback = function()
        if DupeItemName == "" or isDuping then return end

        local items = {}
        for item in DupeItemName:gmatch("([^,]+)") do
            table.insert(items, item:match("^%s*(.-)%s*$"))
        end

        isDuping = true

        task.spawn(function()
            for _, name in ipairs(items) do
                local current = fakeDict[name] or 0
                for i = 1, current do
                    task.wait(0.1)
                    fakeDict[name] = (fakeDict[name] or 0) + 1
                end
            end
            isDuping = false
        end)
    end
})

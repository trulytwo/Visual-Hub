-- ══════════════════════════════════════
-- UpdateInventory Hook
-- ══════════════════════════════════════

UpdateInventory.OnClientEvent:Connect(function(dataType, items)
    if dataType == "Items" then
        if isFiringItems then return end
        if next(fakeItems) == nil then return end
        local now = tick()
        if now - lastFire < DEBOUNCE then return end
        task.spawn(function()
            local modified = false
            for _, item in ipairs(items) do
                local fake = fakeItems[item.name]
                if fake and fake > item.quantity then
                    item.quantity = fake
                    modified = true
                end
            end
            for name, qty in pairs(fakeItems) do
                local found = false
                for _, item in ipairs(items) do
                    if item.name == name then found = true break end
                end
                if not found then
                    table.insert(items, { name = name, quantity = qty, image = "rbxassetid://129120260132029" })
                    modified = true
                end
            end
            if modified then
                lastFire = tick()
                isFiringItems = true
                firesignal(UpdateInventory.OnClientEvent, "Items", items)
                isFiringItems = false
            end
        end)

    elseif dataType == "Sword" then
        if isFiringSwords then return end
        if next(fakeSwords) == nil then return end
        task.spawn(function()
            local modified = false
            for _, item in ipairs(items) do
                local fake = fakeSwords[item.name]
                if fake then item.quantity = fake modified = true end
            end
            for name, qty in pairs(fakeSwords) do
                local found = false
                for _, item in ipairs(items) do
                    if item.name == name then found = true break end
                end
                if not found then
                    table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
                    modified = true
                end
            end
            if modified then
                isFiringSwords = true
                firesignal(UpdateInventory.OnClientEvent, "Sword", items)
                isFiringSwords = false
            end
        end)

    elseif dataType == "Melee" then
        if isFiringMelees then return end
        if next(fakeMelees) == nil then return end
        task.spawn(function()
            local modified = false
            for _, item in ipairs(items) do
                local fake = fakeMelees[item.name]
                if fake then item.quantity = fake modified = true end
            end
            for name, qty in pairs(fakeMelees) do
                local found = false
                for _, item in ipairs(items) do
                    if item.name == name then found = true break end
                end
                if not found then
                    table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
                    modified = true
                end
            end
            if modified then
                isFiringMelees = true
                firesignal(UpdateInventory.OnClientEvent, "Melee", items)
                isFiringMelees = false
            end
        end)
    end
end)

local fakeTitleData = nil
local titleFiring = false

TitleDataSync.OnClientEvent:Connect(function(data)
    if titleFiring or not data then return end
    if fakeTitleData then
        task.spawn(function()
            titleFiring = true
            firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
            titleFiring = false
        end)
    end
end)

-- ══════════════════════════════════════
-- Core Functions
-- ══════════════════════════════════════

local function giveItem(itemName, amount)
    if SWORD_SET[itemName] then
        fakeSwords[itemName] = (fakeSwords[itemName] or 0) + amount
    elseif MELEE_SET[itemName] then
        fakeMelees[itemName] = (fakeMelees[itemName] or 0) + amount
    else
        fakeItems[itemName] = (fakeItems[itemName] or 0) + amount
    end
    task.spawn(function()
        firesignal(NotifyItemDrop.OnClientEvent, {
            isBulk = true,
            items = { [itemName] = amount }
        })
    end)
end

local function giveSword(swordName)
    fakeSwords[swordName] = (fakeSwords[swordName] or 0) + 1
    local items = {}
    for name, qty in pairs(fakeSwords) do
        table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
    end
    isFiringSwords = true
    firesignal(UpdateInventory.OnClientEvent, "Sword", items)
    isFiringSwords = false
    task.spawn(function()
        firesignal(NotifyItemDrop.OnClientEvent, {
            isBulk = true,
            items = { [swordName] = 1 }
        })
    end)
end

local function giveMelee(meleeName)
    fakeMelees[meleeName] = (fakeMelees[meleeName] or 0) + 1
    local items = {}
    for name, qty in pairs(fakeMelees) do
        table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
    end
    isFiringMelees = true
    firesignal(UpdateInventory.OnClientEvent, "Melee", items)
    isFiringMelees = false
    task.spawn(function()
        firesignal(NotifyItemDrop.OnClientEvent, {
            isBulk = true,
            items = { [meleeName] = 1 }
        })
    end)
end

local function pushInventory()
    if next(fakeItems) ~= nil then
        local items = {}
        for name, qty in pairs(fakeItems) do
            table.insert(items, { name = name, quantity = qty, image = "rbxassetid://129120260132029" })
        end
        isFiringItems = true
        firesignal(UpdateInventory.OnClientEvent, "Items", items)
        isFiringItems = false
    end
    if next(fakeSwords) ~= nil then
        local items = {}
        for name, qty in pairs(fakeSwords) do
            table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
        end
        isFiringSwords = true
        firesignal(UpdateInventory.OnClientEvent, "Sword", items)
        isFiringSwords = false
    end
    if next(fakeMelees) ~= nil then
        local items = {}
        for name, qty in pairs(fakeMelees) do
            table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
        end
        isFiringMelees = true
        firesignal(UpdateInventory.OnClientEvent, "Melee", items)
        isFiringMelees = false
    end
end

local function setTitle(titleName)
    local seen = {}
    local unlocked = {}
    for _, t in ipairs(ALL_TITLES) do
        if not seen[t] then
            seen[t] = true
            table.insert(unlocked, t)
        end
    end
    fakeTitleData = {
        unlocked = unlocked,
        equipped = titleName,
        progress = {},
        titlePity = {}
    }
    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
        titleFiring = false
    end)
    task.spawn(function()
        firesignal(TitleChatSync.OnClientEvent, "update", player.UserId, titleName)
    end)
end


    SWORDS = {"Shadow","Ragna","Rimuru","Shadow Monarch","True Aizen","Dual Katana","Longsword","Aizen","Sword","Katana","Saber","Abyssal Empress","Dragon Goddess","Escanor","Ice Queen","Gryphon","Ichigo","KatanaSword","IceQueen","AbyssalEmpress","DragonGoddess","Great Mage","Dark Blade","Atomic","Cutlass","Yamato","TrueAizen","ShadowMonarch","GreatMage","Jinwoo"},
    MELEES = {"Strongest Shinobi","StrongestOfToday","TheWorld","MoonSlayer","Gojo","Yuji","Brass Knuckles","Strongest Of Today","BlessedMaiden","Cosmic Being","Dragon Gauntlets","Combat","Gauntlets","Anos","SaberAlter","Alucard","Fists","Sukuna","StrongestInHistory","The World","CosmicBeing","Madoka","Qin Shi","Saber Alter","Moon Slayer","Gilgamesh","StrongestShinobi","Fighting Style","Blessed Maiden","Strongest In History"}
}

local function getItemType(name)
    for _, v in ipairs(GAME_DATA.SWORDS) do if v == name then return "Swords" end end
    for _, v in ipairs(GAME_DATA.MELEES) do if v == name then return "Melee" end end
    return "Items"
end

-- ================= INVENTORY =================
local fakeDict = {}
local isFiring = false
local lastFire = 0
local DEBOUNCE = 0.5

UpdateInventory.OnClientEvent:Connect(function(dataType, items)
    if isFiring or not items then return end
    if next(fakeDict) == nil then return end
    local now = tick()
    if now - lastFire < DEBOUNCE then return end

    task.spawn(function()
        local modified = false
        for _, item in ipairs(items) do
            local fake = fakeDict[item.name]
            if fake and fake > item.quantity then
                item.quantity = fake
                modified = true
            end
        end
        for name, qty in pairs(fakeDict) do
            local found = false
            for _, item in ipairs(items) do if item.name == name then found = true break end end
            if not found then
                table.insert(items, { name = name, quantity = qty, image = "rbxassetid://129120260132029" })
                modified = true
            end
        end
        if modified then
            lastFire = tick()
            isFiring = true
            local categorized = {Items = {}, Swords = {}, Melee = {}}
            for _, item in ipairs(items) do
                local t = getItemType(item.name)
                table.insert(categorized[t], item)
            end
            for category, data in pairs(categorized) do
                if #data > 0 then firesignal(UpdateInventory.OnClientEvent, category, data) end
            end
            isFiring = false
        end
    end)
end)

local function giveItem(itemName, amount)
    fakeDict[itemName] = (fakeDict[itemName] or 0) + amount
end


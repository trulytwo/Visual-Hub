-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 4483362458)
local SelectedDupeItem = ITEMS[1]
local isDuping = false

DupeTab:CreateParagraph({
    Title = "ℹ️ Info",
    Content = "Select an item and press Dupe. The item will be doubled over time."
})

DupeTab:CreateDropdown({
    Name = "Select Item",
    Options = ITEMS,
    CurrentOption = {ITEMS[1]},
    Flag = "DupeDropdown",
    Callback = function(value)
        SelectedDupeItem = value[1] or value
    end,
})

DupeTab:CreateButton({
    Name = "Dupe (2x)",
    Callback = function()
        if isDuping then
            Rayfield:Notify({ Title = "Error", Content = "Already duping! Please wait.", Duration = 3 })
            return
        end

        local itemName = SelectedDupeItem
        local currentAmount = fakeDict[itemName] or 0

        if currentAmount <= 0 then
            Rayfield:Notify({ Title = "Error", Content = "You don't have " .. itemName .. " in your inventory!", Duration = 3 })
            return
        end

        local targetAmount = currentAmount * 2
        local estimatedTime = math.random(30, 35)
        isDuping = true

        Rayfield:Notify({
            Title = "Duping " .. itemName,
            Content = "Estimated time: " .. estimatedTime .. "s",
            Duration = 5
        })

        task.spawn(function()
            local interval = estimatedTime / (targetAmount - currentAmount)

            while fakeDict[itemName] < targetAmount do
                task.wait(interval)
                fakeDict[itemName] = (fakeDict[itemName] or 0) + 1

                if (fakeDict[itemName] - currentAmount) % 5 == 0 then
                    isFiring = true
                    local items = {}
                    for name, qty in pairs(fakeDict) do
                        table.insert(items, {
                            name = name,
                            quantity = qty,
                            image = "rbxassetid://129120260132029"
                        })
                    end
                    firesignal(UpdateInventory.OnClientEvent, "Items", items)
                    isFiring = false
                end
            end

            fakeDict[itemName] = targetAmount
            isFiring = true
            local items = {}
            for name, qty in pairs(fakeDict) do
                table.insert(items, {
                    name = name,
                    quantity = qty,
                    image = "rbxassetid://129120260132029"
                })
            end
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false

            isDuping = false
            Rayfield:Notify({
                Title = "Dupe Complete!",
                Content = itemName .. " duped to " .. targetAmount,
                Duration = 5
            })
        end)
    end,
})

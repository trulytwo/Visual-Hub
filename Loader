-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 4483362458)
local DupeItemName = ""
local isDuping = false

DupeTab:CreateParagraph({
    Title = "ℹ️ Info",
    Content = "Type an item name and press Dupe. The item will be doubled over time."
})

DupeTab:CreateInput({
    Name = "Item Name",
    PlaceholderText = "e.g. Aura Crate",
    RemoveTextAfterFocusLost = false,
    Callback = function(value)
        DupeItemName = value
    end,
})

DupeTab:CreateButton({
    Name = "Dupe (2x)",
    Callback = function()
        if DupeItemName == "" then
            Rayfield:Notify({ Title = "Error", Content = "Enter an item name!", Duration = 3 })
            return
        end
        if isDuping then
            Rayfield:Notify({ Title = "Error", Content = "Already duping! Please wait.", Duration = 3 })
            return
        end

        local itemName = DupeItemName
        local isSword = SWORD_SET[itemName]
        local isMelee = MELEE_SET[itemName]
        local currentAmount = fakeItems[itemName] or fakeSwords[itemName] or fakeMelees[itemName] or 0

        if currentAmount <= 0 then
            Rayfield:Notify({ Title = "Error", Content = "You don't have " .. itemName .. " in your inventory!", Duration = 3 })
            return
        end

        local targetAmount = currentAmount * 2
        local estimatedTime = math.random(30, 35)
        isDuping = true

        Rayfield:Notify({
            Title = "Duping " .. itemName,
            Content = "Estimated time: " .. estimatedTime .. "s",
            Duration = 5
        })

        task.spawn(function()
            local interval = estimatedTime / (targetAmount - currentAmount)

            local function getCurrent()
                if isSword then return fakeSwords[itemName] or 0
                elseif isMelee then return fakeMelees[itemName] or 0
                else return fakeItems[itemName] or 0 end
            end

            local function increment()
                if isSword then fakeSwords[itemName] = (fakeSwords[itemName] or 0) + 1
                elseif isMelee then fakeMelees[itemName] = (fakeMelees[itemName] or 0) + 1
                else fakeItems[itemName] = (fakeItems[itemName] or 0) + 1 end
            end

            while getCurrent() < targetAmount do
                task.wait(interval)
                increment()
            end

            local items = {}
            if isSword then
                for name, qty in pairs(fakeSwords) do
                    table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
                end
                isFiringSwords = true
                firesignal(UpdateInventory.OnClientEvent, "Sword", items)
                isFiringSwords = false
            elseif isMelee then
                for name, qty in pairs(fakeMelees) do
                    table.insert(items, { name = name, quantity = qty, image = "rbxassetid://0" })
                end
                isFiringMelees = true
                firesignal(UpdateInventory.OnClientEvent, "Melee", items)
                isFiringMelees = false
            else
                for name, qty in pairs(fakeItems) do
                    table.insert(items, { name = name, quantity = qty, image = "rbxassetid://129120260132029" })
                end
                isFiringItems = true
                firesignal(UpdateInventory.OnClientEvent, "Items", items)
                isFiringItems = false
            end

            isDuping = false
            Rayfield:Notify({
                Title = "Dupe Complete!",
                Content = itemName .. " duped to " .. targetAmount,
                Duration = 5
            })
        end)
    end,
})

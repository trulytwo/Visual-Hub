-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 4483362458)
local DupeItemName = ""
local isDuping = false

DupeTab:CreateParagraph({
    Title = "ℹ️ Info",
    Content = "Type item name(s) and press Dupe. Use commas to dupe multiple items at once."
})

DupeTab:CreateInput({
    Name = "Item Name(s)",
    PlaceholderText = "e.g. Aura Crate or Aura Crate, Cosmetic Crate",
    RemoveTextAfterFocusLost = false,
    Callback = function(value)
        DupeItemName = value
    end,
})

DupeTab:CreateButton({
    Name = "Dupe (2x)",
    Callback = function()
        if DupeItemName == "" then
            Rayfield:Notify({ Title = "Error", Content = "Enter item name(s)!", Duration = 3 })
            return
        end
        if isDuping then
            Rayfield:Notify({ Title = "Error", Content = "Already duping! Please wait.", Duration = 3 })
            return
        end

        local itemNames = {}
        for item in DupeItemName:gmatch("([^,]+)") do
            local trimmed = item:match("^%s*(.-)%s*$")
            if trimmed ~= "" then
                table.insert(itemNames, trimmed)
            end
        end

        if #itemNames == 0 then
            Rayfield:Notify({ Title = "Error", Content = "Enter item name(s)!", Duration = 3 })
            return
        end

        for _, itemName in ipairs(itemNames) do
            local cur = fakeItems[itemName] or fakeSwords[itemName] or fakeMelees[itemName] or 0
            if cur <= 0 then
                Rayfield:Notify({ Title = "Error", Content = "You don't have " .. itemName .. "!", Duration = 3 })
                return
            end
        end

        local estimatedTime = math.random(30, 35)
        isDuping = true

        Rayfield:Notify({
            Title = "Duping " .. #itemNames .. " item(s)",
            Content = "Estimated time: " .. estimatedTime .. "s",
            Duration = 5
        })

        task.spawn(function()
            local itemData = {}
            for _, itemName in ipairs(itemNames) do
                local cur = fakeItems[itemName] or fakeSwords[itemName] or fakeMelees[itemName] or 0
                itemData[itemName] = { current = cur, target = cur * 2 }
            end

            local totalIncreases = 0
            for _, data in pairs(itemData) do
                totalIncreases = totalIncreases + (data.target - data.current)
            end

            local interval = estimatedTime / totalIncreases

            local allDone = false
            while not allDone do
                allDone = true
                for _, itemName in ipairs(itemNames) do
                    local isSword = SWORD_SET[itemName]
                    local isMelee = MELEE_SET[itemName]
                    local cur = isSword and (fakeSwords[itemName] or 0) or isMelee and (fakeMelees[itemName] or 0) or (fakeItems[itemName] or 0)
                    if cur < itemData[itemName].target then
                        task.wait(interval)
                        if isSword then
                            fakeSwords[itemName] = (fakeSwords[itemName] or 0) + 1
                        elseif isMelee then
                            fakeMelees[itemName] = (fakeMelees[itemName] or 0) + 1
                        else
                            fakeItems[itemName] = (fakeItems[itemName] or 0) + 1
                        end
                        allDone = false
                    end
                end
            end

            pushInventory()
            isDuping = false
            Rayfield:Notify({
                Title = "Dupe Complete!",
                Content = #itemNames .. " item(s) duped!",
                Duration = 5
            })
        end)
    end,
})

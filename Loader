-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 4483362458)
local DupeItemName = ""
local isDuping = false

DupeTab:CreateParagraph({
    Title = "ℹ️ Info",
    Content = "Type an item name and press Dupe. The item will be doubled over time."
})

DupeTab:CreateInput({
    Name = "Item Name",
    PlaceholderText = "e.g. Aura Crate",
    RemoveTextAfterFocusLost = false,
    Callback = function(value)
        DupeItemName = value
    end,
})

DupeTab:CreateButton({
    Name = "Dupe (2x)",
    Callback = function()
        if DupeItemName == "" then
            Rayfield:Notify({ Title = "Error", Content = "Enter an item name!", Duration = 3 })
            return
        end
        if isDuping then
            Rayfield:Notify({ Title = "Error", Content = "Already duping! Please wait.", Duration = 3 })
            return
        end

        local itemName = DupeItemName
        local currentAmount = fakeDict[itemName] or 0

        if currentAmount <= 0 then
            Rayfield:Notify({ Title = "Error", Content = "You dont have " .. itemName .. " in your inventory!", Duration = 3 })
            return
        end

        local targetAmount = currentAmount * 2
        local estimatedTime = math.random(30, 35)
        isDuping = true

        Rayfield:Notify({
            Title = "Duping " .. itemName,
            Content = "Estimated time: " .. estimatedTime .. "s",
            Duration = 5
        })

        task.spawn(function()
            local elapsed = 0
            local interval = estimatedTime / (targetAmount - currentAmount)

            while fakeDict[itemName] < targetAmount do
                task.wait(interval)
                fakeDict[itemName] = (fakeDict[itemName] or 0) + 1
                elapsed = elapsed + interval

                -- Update inventory every 5 items so it feels natural
                if (fakeDict[itemName] - currentAmount) % 5 == 0 then
                    isFiring = true
                    local items = {}
                    for name, qty in pairs(fakeDict) do
                        table.insert(items, {
                            name = name,
                            quantity = qty,
                            image = "rbxassetid://129120260132029"
                        })
                    end
                    firesignal(UpdateInventory.OnClientEvent, "Items", items)
                    isFiring = false
                end
            end

            -- Final update
            fakeDict[itemName] = targetAmount
            isFiring = true
            local items = {}
            for name, qty in pairs(fakeDict) do
                table.insert(items, {
                    name = name,
                    quantity = qty,
                    image = "rbxassetid://129120260132029"
                })
            end
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false

            isDuping = false
            Rayfield:Notify({
                Title = "Dupe Complete!",
                Content = itemName .. " duped to " .. targetAmount,
                Duration = 5
            })
        end)
    end,
})

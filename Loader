local fakeDict = {} 
local isFiring = false
local lastFire = 0
local DEBOUNCE = 0.5

local function getCategory(name)
    if Database.Melee[name] then return "Melee" end
    if Database.Swords[name] then return "Swords" end
    return "Items"
end

UpdateInventory.OnClientEvent:Connect(function(dataType, items)
    if isFiring or dataType ~= "Items" or not items then return end
    if next(fakeDict) == nil then return end
    local now = tick()
    if now - lastFire < DEBOUNCE then return end
    task.spawn(function()
        local modified = false
        for _, item in ipairs(items) do
            local fake = fakeDict[item.name]
            if fake and fake.qty > item.quantity then
                item.quantity = fake.qty
                modified = true
            end
        end
        for name, data in pairs(fakeDict) do
            local found = false
            for _, item in ipairs(items) do
                if item.name == name then found = true break end
            end
            if not found then
                table.insert(items, { name = name, quantity = data.qty, type = data.cat, image = "rbxassetid://129120260132029" })
                modified = true
            end
        end
        if modified then
            lastFire = tick()
            isFiring = true
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false
        end
    end)
end)

local fakeTitleData = nil
local titleFiring = false

TitleDataSync.OnClientEvent:Connect(function(data)
    if titleFiring or not data then return end
    if fakeTitleData then
        task.spawn(function()
            titleFiring = true
            firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
            titleFiring = false
        end)
    end
end)

local function giveItem(itemName, amount)
    local cat = getCategory(itemName)
    fakeDict[itemName] = {qty = (fakeDict[itemName] and fakeDict[itemName].qty or 0) + amount, cat = cat}
end

local function setTitle(titleName)
    fakeTitleData = {unlocked = {titleName}, equipped = titleName, progress = {}, titlePity = {}}
    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
        titleFiring = false
        firesignal(TitleChatSync.OnClientEvent, "update", player.UserId, titleName)
    end)
end


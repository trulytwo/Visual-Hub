-- Inventory
local fakeDict = {}
local isFiring = false
local lastFire = 0
local DEBOUNCE = 0.5

UpdateInventory.OnClientEvent:Connect(function(dataType, items)
    if isFiring or dataType ~= "Items" or not items then return end
    if next(fakeDict) == nil then return end
    local now = tick()
    if now - lastFire < DEBOUNCE then return end
    task.spawn(function()
        local modified = false
        for _, item in ipairs(items) do
            local fake = fakeDict[item.name]
            if fake and fake > item.quantity then
                item.quantity = fake
                modified = true
            end
        end
        for name, qty in pairs(fakeDict) do
            local found = false
            for _, item in ipairs(items) do
                if item.name == name then found = true break end
            end
            if not found then
                table.insert(items, { name = name, quantity = qty, image = "rbxassetid://129120260132029" })
                modified = true
            end
        end
        if modified then
            lastFire = tick()
            isFiring = true
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false
        end
    end)
end)

-- Title
local equippedTitle = "Novice"
local titleFiring = false
local realProgress = {}
local realPity = {}

TitleDataSync.OnClientEvent:Connect(function(data)
    if titleFiring or not data then return end
    if data.progress then realProgress = data.progress end
    if data.titlePity then realPity = data.titlePity end
    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, {
            unlocked = TITLES,
            equipped = equippedTitle,
            progress = realProgress,
            titlePity = realPity
        })
        titleFiring = false
    end)
end)

-- Equip
local fakeEquipped = nil
local equippedFiring = false
local realEquipped = {}

UpdateEquipped.OnClientEvent:Connect(function(data)
    if equippedFiring or not data then return end
    realEquipped = data
    if fakeEquipped then
        task.spawn(function()
            equippedFiring = true
            firesignal(UpdateEquipped.OnClientEvent, fakeEquipped)
            equippedFiring = false
        end)
    end
end)

local function setEquipped(slot, itemName)
    local newEquipped = {}
    for k, v in pairs(realEquipped) do
        newEquipped[k] = v
    end
    if fakeEquipped then
        for k, v in pairs(fakeEquipped) do
            newEquipped[k] = v
        end
    end
    if itemName == "None" then
        newEquipped[slot] = nil
    else
        newEquipped[slot] = itemName
    end
    fakeEquipped = newEquipped
    task.spawn(function()
        equippedFiring = true
        firesignal(UpdateEquipped.OnClientEvent, fakeEquipped)
        equippedFiring = false
    end)
end

local function giveItem(itemName, amount)
    fakeDict[itemName] = (fakeDict[itemName] or 0) + amount
    task.spawn(function()
        firesignal(NotifyItemDrop.OnClientEvent, {
            isBulk = true,
            items = { [itemName] = amount }
        })
    end)
end

local function setTitle(titleName)
    equippedTitle = titleName
    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, {
            unlocked = TITLES,
            equipped = equippedTitle,
            progress = realProgress,
            titlePity = realPity
        })
        titleFiring = false
    end)
    task.spawn(function()
        firesignal(TitleChatSync.OnClientEvent, "update", player.UserId, titleName)
    end)
end


local fakeDict = {} 
local isFiring = false
local lastFire = 0
local DEBOUNCE = 0.5

local function getCategory(name)
    if MeleeList[name] then return "Melee" end
    return "Items" -- Everything else defaults to Items
end

UpdateInventory.OnClientEvent:Connect(function(dataType, items)
    if isFiring or dataType ~= "Items" or not items then return end
    local now = tick()
    if now - lastFire < DEBOUNCE then return end
    
    task.spawn(function()
        local modified = false
        for _, item in ipairs(items) do
            if fakeDict[item.name] and fakeDict[item.name].qty > item.quantity then
                item.quantity = fakeDict[item.name].qty
                item.type = getCategory(item.name) -- Ensure type matches
                modified = true
            end
        end
        for name, data in pairs(fakeDict) do
            local found = false
            for _, item in ipairs(items) do
                if item.name == name then found = true break end
            end
            if not found then
                table.insert(items, { name = name, quantity = data.qty, type = data.category, image = "rbxassetid://129120260132029" })
                modified = true
            end
        end
        if modified then
            lastFire = tick()
            isFiring = true
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false
        end
    end)
end)

local function giveItem(itemName, amount)
    local cat = getCategory(itemName)
    if not fakeDict[itemName] then
        fakeDict[itemName] = {qty = amount, category = cat}
    else
        fakeDict[itemName].qty = fakeDict[itemName].qty + amount
    end
end


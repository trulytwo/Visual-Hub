local fakeTitleData = nil
local titleFiring = false

TitleDataSync.OnClientEvent:Connect(function(data)
    if titleFiring or not data then return end
    if fakeTitleData then
        task.spawn(function()
            titleFiring = true
            firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
            titleFiring = false
        end)
    end
end)

local function setTitle(titleName)
    local allUnlocked = {}

    for _, t in ipairs(GAME_DATA.TITLES) do
        table.insert(allUnlocked, t)
    end

    table.insert(allUnlocked, titleName)

    fakeTitleData = {
        unlocked = allUnlocked,
        equipped = titleName,
        progress = {},
        titlePity = {}
    }

    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
        titleFiring = false
    end)

    task.spawn(function()
        firesignal(TitleChatSync.OnClientEvent, "update", player.UserId, titleName)
    end)
end

local function giveItem(name, amount)
    fakeDict[name] = (fakeDict[name] or 0) + amount
end


-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 0)
local DupeInput = ""
DupeTab:CreateInput({Name = "Item Name", Callback = function(v) DupeInput = v end})
DupeTab:CreateButton({Name = "Dupe (2x)", Callback = function()
    if isDuping or not fakeDict[DupeInput] then return end
    isDuping = true
    local timer = math.random(25, 30)
    Rayfield:Notify({Title = "Duping...", Content = "Time: "..timer.."s", Duration = 5})
    task.wait(timer)
    giveItem(DupeInput, fakeDict[DupeInput].qty)
    isDuping = false
end})

local fakeDict = {}
local isFiring, isDuping = false, false

-- Rayfield UI Setup
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({Name = "Express Hub", DisableRayfieldPrompts = true})

local function getCategory(name)
    for cat, items in pairs(Lists) do
        for _, item in ipairs(items) do if item == name then return cat end end
    end
    return "Items"
end

UpdateInventory.OnClientEvent:Connect(function(type, items)
    if isFiring or type ~= "Items" then return end
    task.spawn(function()
        for name, data in pairs(fakeDict) do
            local found = false
            for _, item in ipairs(items) do
                if item.name == name then item.quantity = data.qty; found = true; break end
            end
            if not found then table.insert(items, {name = name, quantity = data.qty, type = data.cat, image = "rbxassetid://129120260132029"}) end
        end
        isFiring = true
        firesignal(UpdateInventory.OnClientEvent, "Items", items)
        isFiring = false
    end)
end)

local function giveItem(name, amt)
    fakeDict[name] = {qty = (fakeDict[name] and fakeDict[name].qty or 0) + amt, cat = getCategory(name)}
    -- Automatic Notification
    Rayfield:Notify({Title = "Obtained", Content = amt .. "x " .. name, Duration = 3})
end


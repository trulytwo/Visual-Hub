local rs = game:GetService("ReplicatedStorage")
local Remotes = rs:WaitForChild("Remotes")
local RemoteEvents = rs:WaitForChild("RemoteEvents")
local NotifyItemDrop = Remotes:WaitForChild("NotifyItemDrop")
local UpdateInventory = Remotes:WaitForChild("UpdateInventory")
local TitleDataSync = RemoteEvents:WaitForChild("TitleDataSync")
local TitleChatSync = RemoteEvents:WaitForChild("TitleChatSync")

local fakeDict = {}
local isFiring = false
local lastFire = 0
local DEBOUNCE = 0.5

UpdateInventory.OnClientEvent:Connect(function(dataType, items)
    if isFiring or dataType ~= "Items" or not items then return end
    if next(fakeDict) == nil then return end
    local now = tick()
    if now - lastFire < DEBOUNCE then return end
    task.spawn(function()
        local modified = false
        for _, item in ipairs(items) do
            local fake = fakeDict[item.name]
            if fake and fake > item.quantity then
                item.quantity = fake
                modified = true
            end
        end
        for name, qty in pairs(fakeDict) do
            local found = false
            for _, item in ipairs(items) do
                if item.name == name then found = true break end
            end
            if not found then
                table.insert(items, { name = name, quantity = qty, image = "rbxassetid://129120260132029" })
                modified = true
            end
        end
        if modified then
            lastFire = tick()
            isFiring = true
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false
        end
    end)
end)

local fakeTitleData = nil
local titleFiring = false

TitleDataSync.OnClientEvent:Connect(function(data)
    if titleFiring or not data then return end
    if fakeTitleData then
        task.spawn(function()
            titleFiring = true
            firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
            titleFiring = false
        end)
    end
end)

local function giveItem(itemName, amount)
    fakeDict[itemName] = (fakeDict[itemName] or 0) + amount
end

local function setTitle(titleName)
    local allUnlocked = {
        "Novice", "Apprentice", "Warrior", "Champion", "King",
        "Collector", "Hoarder", "Treasure Hunter", "Lucky Novice",
        "Fortune Seeker", "Lucky Star", "Blessed One", "Blessed Sovereign",
        "Celestial Favor", "Golden Tyrant", "Blade Master", "Living Weapon",
        "Curse King", "Shadow Monarch", "Manipulator", "Eminence in Shadow",
        "King of Beginning", "Vampire King", "Demon Lord", "Dragon Slayer",
        "Blade Sovereign", "Star Maiden", "Strongest Sorcerer", "The Chosen One",
        "Domain Master", "Eminence Incarnate", "Transcendent Being", "Astral Empress",
        "King of Shadows", "Frost Empress", "The One", "Void Empress",
        "Shadow King", "Strongest Shinobi", "Santa's Helper", titleName
    }

    local seen = {}
    local unlocked = {}
    for _, t in ipairs(allUnlocked) do
        if not seen[t] then
            seen[t] = true
            table.insert(unlocked, t)
        end
    end

    fakeTitleData = {
        unlocked = unlocked,
        equipped = titleName,
        progress = {},
        titlePity = {}
    }

    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
        titleFiring = false
    end)

    task.spawn(function()
        firesignal(TitleChatSync.OnClientEvent, "update", player.UserId, titleName)
    end)
end


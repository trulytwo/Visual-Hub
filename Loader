local fakeTitleData = nil
local titleFiring = false

local function setTitle(titleName)
    local allUnlocked = {"Novice", "Apprentice", "Warrior", "Champion", "King", "Collector", "Hoarder", "Treasure Hunter", "Lucky Novice", "Fortune Seeker", "Lucky Star", "Blessed One", "Blessed Sovereign", "Celestial Favor", "Golden Tyrant", "Blade Master", "Living Weapon", "Curse King", "Shadow Monarch", "Manipulator", "Eminence in Shadow", "King of Beginning", "Vampire King", "Demon Lord", "Dragon Slayer", "Blade Sovereign", "Star Maiden", "Strongest Sorcerer", "The Chosen One", "Domain Master", "Eminence Incarnate", "Transcendent Being", "Astral Empress", "King of Shadows", "Frost Empress", "The One", "Void Empress", "Shadow King", "Strongest Shinobi", "Santa's Helper", titleName}
    fakeTitleData = {unlocked = allUnlocked, equipped = titleName, progress = {}, titlePity = {}}
    task.spawn(function()
        titleFiring = true
        firesignal(TitleDataSync.OnClientEvent, fakeTitleData)
        titleFiring = false
        firesignal(TitleChatSync.OnClientEvent, "update", player.UserId, titleName)
    end)
end


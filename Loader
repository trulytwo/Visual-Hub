-- ══════════════════════════════════════
-- Dupe Tab
-- ══════════════════════════════════════

local DupeItemName = ""
local isDuping = false

Tabs.Dupe:Section({ Title = "Item Duplicator" })

Tabs.Dupe:Input({
    Title = "Item Name",
    Placeholder = "e.g. Aura Crate",
    Callback = function(value)
        DupeItemName = value
    end,
})

Tabs.Dupe:Button({
    Title = "Dupe (2x)",
    Callback = function()
        if DupeItemName == "" then
            WindUI:Notify({ Title = "Error", Content = "Enter an item name!", Duration = 3 })
            return
        end
        if isDuping then
            WindUI:Notify({ Title = "Error", Content = "Already duping! Please wait.", Duration = 3 })
            return
        end

        local itemName = DupeItemName
        local isSword = SWORD_SET[itemName]
        local isMelee = MELEE_SET[itemName]
        local currentAmount = fakeItems[itemName] or fakeSwords[itemName] or fakeMelees[itemName] or 0

        if currentAmount <= 0 then
            WindUI:Notify({ Title = "Error", Content = "You don't have " .. itemName .. " in your inventory!", Duration = 3 })
            return
        end

        local targetAmount = currentAmount * 2
        local estimatedTime = math.random(30, 35)
        isDuping = true

        WindUI:Notify({
            Title = "Duping " .. itemName,
            Content = "Estimated time: " .. estimatedTime .. "s",
            Duration = 5,
        })

        task.spawn(function()
            local interval = estimatedTime / (targetAmount - currentAmount)

            local function getCurrent()
                if isSword then return fakeSwords[itemName] or 0
                elseif isMelee then return fakeMelees[itemName] or 0
                else return fakeItems[itemName] or 0 end
            end

            local function increment()
                if isSword then fakeSwords[itemName] = (fakeSwords[itemName] or 0) + 1
                elseif isMelee then fakeMelees[itemName] = (fakeMelees[itemName] or 0) + 1
                else fakeItems[itemName] = (fakeItems[itemName] or 0) + 1 end
            end

            while getCurrent() < targetAmount do
                task.wait(interval)
                increment()
            end

            pushInventory()
            isDuping = false

            WindUI:Notify({
                Title = "Dupe Complete!",
                Content = itemName .. " duped to " .. targetAmount,
                Duration = 5,
            })
        end)
    end,
})

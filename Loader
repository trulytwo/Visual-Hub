-- Dupe Tab
local DupeTab = Window:CreateTab("Dupe", 4483362458)
local DupeItemName = ""
local isDuping = false

DupeTab:CreateParagraph({
    Title = "ℹ️ Info",
    Content = "Type item name(s) and press Dupe. Items will be doubled over time. Use commas to dupe multiple items at once (e.g. Aura Crate, Cosmetic Crate)"
})

DupeTab:CreateInput({
    Name = "Item Name(s)",
    PlaceholderText = "e.g. Aura Crate or Aura Crate, Cosmetic Crate",
    RemoveTextAfterFocusLost = false,
    Callback = function(value)
        DupeItemName = value
    end,
})

DupeTab:CreateButton({
    Name = "Dupe (2x)",
    Callback = function()
        if DupeItemName == "" then
            Rayfield:Notify({ Title = "Error", Content = "Enter item name(s)! Use commas to separate.", Duration = 3 })
            return
        end
        if isDuping then
            Rayfield:Notify({ Title = "Error", Content = "Already duping! Please wait.", Duration = 3 })
            return
        end

        -- Split input by comma and trim whitespace
        local itemNames = {}
        for item in DupeItemName:gmatch("([^,]+)") do
            local trimmed = item:match("^%s*(.-)%s*$")
            if trimmed ~= "" then
                table.insert(itemNames, trimmed)
            end
        end

        if #itemNames == 0 then
            Rayfield:Notify({ Title = "Error", Content = "Enter item name(s)!", Duration = 3 })
            return
        end

        -- Validate all items exist
        for _, itemName in ipairs(itemNames) do
            if (fakeDict[itemName] or 0) <= 0 then
                Rayfield:Notify({ Title = "Error", Content = "You don't have " .. itemName .. " in your inventory!", Duration = 3 })
                return
            end
        end

        local estimatedTime = math.random(30, 35)
        isDuping = true

        Rayfield:Notify({
            Title = "Duping " .. #itemNames .. " item(s)",
            Content = "Estimated time: " .. estimatedTime .. "s",
            Duration = 5
        })

        task.spawn(function()
            -- Store initial amounts for all items
            local itemData = {}
            for _, itemName in ipairs(itemNames) do
                itemData[itemName] = {
                    current = fakeDict[itemName],
                    target = fakeDict[itemName] * 2
                }
            end

            local totalIncreases = 0
            for _, data in pairs(itemData) do
                totalIncreases = totalIncreases + (data.target - data.current)
            end

            local interval = estimatedTime / totalIncreases

            -- Dupe all items simultaneously
            local allDone = false
            while not allDone do
                allDone = true
                for _, itemName in ipairs(itemNames) do
                    if fakeDict[itemName] < itemData[itemName].target then
                        task.wait(interval)
                        fakeDict[itemName] = (fakeDict[itemName] or 0) + 1
                        allDone = false

                        -- Update inventory every 5 items so it feels natural
                        if (fakeDict[itemName] - itemData[itemName].current) % 5 == 0 then
                            isFiring = true
                            local items = {}
                            for name, qty in pairs(fakeDict) do
                                table.insert(items, {
                                    name = name,
                                    quantity = qty,
                                    image = "rbxassetid://129120260132029"
                                })
                            end
                            firesignal(UpdateInventory.OnClientEvent, "Items", items)
                            isFiring = false
                        end
                    end
                end
            end

            -- Final update
            isFiring = true
            local items = {}
            for name, qty in pairs(fakeDict) do
                table.insert(items, {
                    name = name,
                    quantity = qty,
                    image = "rbxassetid://129120260132029"
                })
            end
            firesignal(UpdateInventory.OnClientEvent, "Items", items)
            isFiring = false

            isDuping = false
            Rayfield:Notify({
                Title = "Dupe Complete!",
                Content = #itemNames .. " item(s) duped successfully!",
                Duration = 5
            })
        end)
    end,
})
